# ── Base de données ───────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/cannazen

# ── Serveur ───────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080
BASE_PATH=/
SESSION_SECRET=changeme-minimum-32-chars-random-string

# ── Paiements Mollie ──────────────────────────────────────────────
MOLLIE_API_KEY=

# ── Email Brevo ───────────────────────────────────────────────────
BREVO_API_KEY=
BREVO_SENDER_EMAIL=contact@cannazen.fr
BREVO_SENDER_NAME=CannaZen

# ── IA Groq ───────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Expédition Sendcloud ──────────────────────────────────────────
SENDCLOUD_PUBLIC_KEY=
SENDCLOUD_SECRET_KEY=
SENDCLOUD_WEBHOOK_SECRET=

# ── Google OAuth ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
